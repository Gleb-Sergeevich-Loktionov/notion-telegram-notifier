# ── Required ────────────────────────────────────────────────────────────
# Notion internal integration token (starts with secret_...)
NOTION_TOKEN=secret_...

# Telegram Bot token from @BotFather
TELEGRAM_TOKEN=123456789:AAAA...

# Notion database ID (the "All Tasks" database UUID)
NOTION_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Comma-separated list of Telegram chat_ids that are admins
# Get your chat_id by messaging @userinfobot
ADMIN_CHAT_IDS=123456789,987654321

# ── Optional (defaults shown) ────────────────────────────────────────────────
# Path to SQLite database file inside the container
DB_PATH=/data/bot.db

# Seconds between poll cycles
POLL_INTERVAL=90

# Overlap window in seconds for incremental Notion filter (guards against indexing lag)
OVERLAP_SECONDS=300

# IANA timezone for displaying dates in notifications
DISPLAY_TZ=Europe/Moscow

# Notion property names (change only if your database has different column names)
PROP_TITLE=Name
PROP_ASSIGNEE=Assign_new
PROP_REPORTER=Заказчик_new
PROP_STATUS=Status
PROP_PROJECT=Проект
PROP_DUE=Дата

# Status value treated as "done" — new-assignee events suppressed at this status
DONE_STATUS=Готово

# Seconds to cache project titles
PROJECT_CACHE_TTL=86400

# Seconds until an invite code expires
INVITE_TTL=86400

# Maximum wrong code attempts before throttle mute
INVITE_MAX_ATTEMPTS=3

# Путь heartbeat-файла (должен совпадать с healthcheck в docker-compose.yml)
HEARTBEAT_PATH=/tmp/notify_bot_heartbeat

# Опционально: альтернативный Notion API endpoint (тесты/демо). Пусто = боевой.
# NOTION_BASE_URL=http://127.0.0.1:8787
